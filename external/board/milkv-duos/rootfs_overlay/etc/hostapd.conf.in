ctrl_interface=/var/run/hostapd
interface=wlan0

hw_mode={{HW_MODE}}
ieee80211be={{BE_MODE}}
ieee80211ax={{AX_MODE}}
ieee80211ac={{AC_MODE}}
ieee80211n={{N_MODE}}
channel={{CHANNEL}}

auth_algs=1
wpa=2
wpa_key_mgmt=WPA-PSK
wpa_pairwise=CCMP
rsn_pairwise=CCMP

ssid={{SSID}}

wpa_passphrase={{WPA_PASSPHRASE}}
country_code={{COUNTRY_CODE}}

vht_oper_chwidth=1
require_vht=1
wmm_enabled=1
ht_capab=[HT40+][HT40-][SHORT-GI-20][SHORT-GI-40][MAX-AMSDU-7935][RX-LDPC][RX-STBC1]
vht_capab=[MAX-MPDU-11454][SHORT-GI-80][SU-BEAMFORMEE][MU-BEAMFORMEE][MU-BEAMFORMER][RXLDPC]
